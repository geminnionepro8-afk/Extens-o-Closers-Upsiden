{
  "manifest_version": 3,
  "name": "Upsiden — Áudio Instantâneo",
  "version": "3.0.0",
  "description": "Biblioteca de áudios com envio instantâneo como mensagem de voz no WhatsApp Web. Backend Supabase.",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "https://imxwpacwtphekrbgwbph.supabase.co/*"
  ],
  "action": {
    "default_popup": "painel.html",
    "default_icon": {
      "16": "icones/icone16.png",
      "48": "icones/icone48.png",
      "128": "icones/icone128.png"
    }
  },
  "background": {
    "service_worker": "servico_background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://web.whatsapp.com/*"
      ],
      "css": [
        "injetado.css"
      ],
      "js": [
        "content_script.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_page": "opcoes.html",
  "web_accessible_resources": [
    {
      "resources": [
        "wppconnect-wa.js",
        "injetor_pagina.js",
        "injetado.css",
        "icones/*",
        "supabase_client.js",
        "login.html",
        "login.css",
        "login.js",
        "painel.html",
        "painel.css",
        "painel.js",
        "audios.html",
        "audios.css",
        "audios.js",
        "admin.html",
        "admin.css",
        "admin.js",
        "crm.html",
        "crm.css",
        "crm.js",
        "modulo.css",
        "documentos.html",
        "documentos.js",
        "midias.html",
        "midias.js",
        "templates.html",
        "templates.js",
        "notas.html",
        "notas.js",
        "saudacao.html",
        "saudacao.js",
        "triggers.html",
        "triggers.js",
        "supabase.min.js",
        "supabase_config.js"
      ],
      "matches": [
        "https://web.whatsapp.com/*"
      ]
    }
  ],
  "icons": {
    "16": "icones/icone16.png",
    "48": "icones/icone48.png",
    "128": "icones/icone128.png"
  },
  "commands": {
    "acionar-seletor-audio": {
      "suggested_key": {
        "default": "Alt+A"
      },
      "description": "Abrir seletor de arquivo de áudio"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src https://imxwpacwtphekrbgwbph.supabase.co https://*.supabase.co"
  }
}

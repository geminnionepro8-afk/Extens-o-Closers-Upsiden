{
  "manifest_version": 3,
  "name": "Upsiden — Áudio Instantâneo",
  "version": "3.0.0",
  "description": "Biblioteca de áudios com envio instantâneo como mensagem de voz no WhatsApp Web. Backend Supabase.",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "scripting",
    "activeTab",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "https://imxwpacwtphekrbgwbph.supabase.co/*"
  ],
  "action": {
    "default_popup": "src/ui/painel/painel.html",
    "default_icon": {
      "16": "public/icons/icone16.png",
      "48": "public/icons/icone48.png",
      "128": "public/icons/icone128.png"
    }
  },
  "background": {
    "service_worker": "src/core/background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://web.whatsapp.com/*"
      ],
      "css": [
        "src/ui/styles/injetado.css"
      ],
      "js": [
        "src/libs/supabase.min.js",
        "src/libs/supabase-config.js",
        "src/services/auth.service.js",
        "src/services/db.service.js",
        "src/services/storage.service.js",
        "src/core/content-scripts/nav-injector.js",
        "src/core/content-scripts/panel-drawer.js",
        "src/core/content-scripts/quick-actions.js",
        "src/core/content-scripts/chat-filters.js",
        "src/core/content-scripts/ipc-bridge.js",
        "src/ui/modules/audios.js",
        "src/core/content-scripts/content-script.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_page": "src/ui/options/opcoes.html",
  "web_accessible_resources": [
    {
      "resources": [
        "src/core/utils/helper.js",
        "src/core/utils/template-engine.js",
        "src/core/automation/automation-controller.js",
        "src/libs/wppconnect-wa.js",
        "src/core/page-scripts/wpp-engine.js",
        "src/ui/styles/injetado.css",
        "public/icons/*",
        "src/services/auth.service.js",
        "src/services/db.service.js",
        "src/services/storage.service.js",
        "src/services/metrics.service.js",
        "src/libs/supabase.min.js",
        "src/libs/supabase-config.js",
        "src/ui/login/login.html",
        "src/ui/login/login.css",
        "src/ui/login/login.js",
        "src/ui/painel/painel.html",
        "src/ui/painel/painel-init.js",
        "src/ui/painel/painel-helpers.js",
        "src/ui/painel/painel-dashboard.js",
        "src/ui/painel/painel-biblioteca.js",
        "src/ui/painel/painel-templates-crm.js",
        "src/ui/painel/painel-automacoes.js",
        "src/ui/painel/painel-campanhas.js",
        "src/ui/painel/painel-admin.js",
        "src/ui/styles/painel.css",
        "src/ui/styles/modulo.css",
        "src/ui/modules/*"
      ],
      "matches": [
        "https://web.whatsapp.com/*"
      ]
    }
  ],
  "icons": {
    "16": "public/icons/icone16.png",
    "48": "public/icons/icone48.png",
    "128": "public/icons/icone128.png"
  },
  "commands": {
    "acionar-seletor-audio": {
      "suggested_key": {
        "default": "Alt+A"
      },
      "description": "Abrir seletor de arquivo de áudio"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src https://imxwpacwtphekrbgwbph.supabase.co https://*.supabase.co"
  }
}
